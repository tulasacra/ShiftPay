# SideShift REST API (https://docs.sideshift.ai/) — required for the dev-server proxy and `npm run proxy`.
# Never commit real secrets. The browser only talks to your proxy, not to SideShift directly.
SIDESHIFT_SECRET=
SIDESHIFT_AFFILIATE_ID=

# Optional: port for `npm run proxy` (default 8787).
# SIDESHIFT_PROXY_PORT=8787

# Production / static hosting: base URL of a deployed proxy that implements POST /fixed-shift and GET /shifts/:id
# (same routes as the Vite dev middleware under /api/sideshift).
# VITE_SIDESHIFT_API_BASE=https://your-proxy.example.com/api/sideshift
